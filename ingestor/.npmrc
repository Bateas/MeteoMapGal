# Supply-chain hardening for the ingestor (own package.json: pg, sharp,
# dotenv...). npm reads the .npmrc of the CWD only — it does NOT inherit
# the repo-root .npmrc when you `cd ingestor && npm ci`. So this file is
# REQUIRED for the ignore-scripts policy to apply to ingestor deps too.
#
# esbuild (postinstall) + sharp (install: libvips) are re-run explicitly
# after install via:
#   npm rebuild esbuild sharp --foreground-scripts --ignore-scripts=false
# Baked into CI + meteomap-update. See CLAUDE.md
# "PROTOCOLO DEPENDENCIAS / SUPPLY-CHAIN".
ignore-scripts=true
