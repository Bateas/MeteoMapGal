# MeteoMapGal Ingestor — Environment Variables
# Copy to .env and fill in your values

# AEMET API key (required)
AEMET_API_KEY=your_aemet_api_key_here

# Weather Underground API key (public, hardcoded fallback exists)
WU_API_KEY=e1f10a1e78da46f5b10a1e78da96f525

# TimescaleDB connection
DB_HOST=REDACTED_DB_HOST
DB_PORT=5432
DB_NAME=meteomapgal
DB_USER=meteomap_app
DB_PASSWORD=REDACTED_PASSWORD

# Observatorio Costeiro da Xunta API key (for buoy data)
# Same JWT as VITE_OBSCOSTEIRO_API_KEY in root .env
OBSCOSTEIRO_API_KEY=your_obscosteiro_api_key_here

# Polling interval in minutes (default: 5)
POLL_INTERVAL_MIN=5

# Station re-discovery interval in minutes (default: 60)
DISCOVER_INTERVAL_MIN=60
