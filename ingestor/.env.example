# MeteoMapGal Ingestor — Environment Variables
# Copy to .env and fill in your values

# AEMET API key (required)
AEMET_API_KEY=your_aemet_api_key_here

# Weather Underground API key
# This is IBM's PUBLIC key, embedded in wunderground.com page source.
# Extracted from their site, not a credential. Hardcoded fallback exists in code
# (removing it broke discovery — see commits 9f07f33 → 58ea5ca). Override here if needed.
WU_API_KEY=e1f10a1e78da46f5b10a1e78da96f525

# SkyX auth token (PUBLIC — extracted from their web client, not a private credential)
# Optional: omit to use the in-code fallback. Single Cesantes station.
# SKYX_AUTH=a21bd737-a714-4a5c-9b08-e7d3d2693a51

# TimescaleDB connection
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=meteomapgal
DB_USER=meteomap_app
DB_PASSWORD=your_secure_password_here

# Observatorio Costeiro da Xunta API key (for buoy data)
# Same JWT as VITE_OBSCOSTEIRO_API_KEY in root .env
OBSCOSTEIRO_API_KEY=your_obscosteiro_api_key_here

# Polling interval in minutes (default: 5)
POLL_INTERVAL_MIN=5

# Station re-discovery interval in minutes (default: 60)
DISCOVER_INTERVAL_MIN=60
