# ─────────────────────────────────────────────────────────────
# MeteoMap — Deploy Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
# ─────────────────────────────────────────────────────────────

# LXC container IP or hostname (reachable from your dev machine)
LXC_HOST=192.168.1.100

# SSH user on the LXC (default: root for Proxmox LXC)
LXC_USER=root

# SSH port (default: 22)
LXC_PORT=22

# Optional: SSH key path (leave empty to use default ~/.ssh/id_rsa)
# SSH_KEY=~/.ssh/proxmox_lxc

# Optional: Proxmox host for pct commands (if deploying via Proxmox API)
# PVE_HOST=192.168.1.1
# LXC_CTID=110
